<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:FishingFloatApp"
    xmlns:tb="http://www.hardcodet.net/taskbar"
    xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" 
    d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel}"
    x:Class="FishingFloatApp.MainWindow"
    mc:Ignorable="d"
    AllowsTransparency="True"
    Background="{Binding BackgroundColor}"
    WindowStyle="None"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    Topmost="True"
    Title="{Binding Title}" 
    Left="{Binding Path=Left, Mode=TwoWay}"
    Top="{Binding Path=Top, Mode=TwoWay}"
    Height="{Binding Path=Height, Mode=TwoWay}" 
    Width="{Binding Path=Width, Mode=TwoWay}">
    <WindowChrome.WindowChrome>
        <WindowChrome
                CaptionHeight="0"
                ResizeBorderThickness="5"
                GlassFrameThickness="0"
                UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ContextMenu x:Key="menu">
            <MenuItem Header="悬浮窗设置" Click="ClickSetting" />
            <MenuItem Header="历史记录" Click="ClickHistory" />
            <MenuItem Header="导出钓鱼笔记" Click="ClickExport" />
            <Separator />
            <MenuItem Header="刷新" Click="ClickRefresh" />
            <MenuItem Header="窗口锁定/穿透" IsCheckable="True" IsChecked="{Binding Transparent}" />
            <MenuItem Header="退出" Click="ClickExit" />
        </ContextMenu>
        <ContextMenu x:Key="webview_menu">
            <MenuItem Header="窗口锁定/穿透" IsCheckable="True" IsChecked="{Binding Transparent}" />
        </ContextMenu>
    </Window.Resources>
    <Grid>
        <tb:TaskbarIcon ToolTipText="杆时悬浮窗" ContextMenu="{StaticResource ResourceKey=menu}" IconSource="/icon.ico">
        </tb:TaskbarIcon>
        <Wpf:WebView2 Margin="4, 4, 4, 4" x:Name="webview" Source="{Binding ShowingUri}" DefaultBackgroundColor="Transparent"/>
    </Grid>
</Window>
