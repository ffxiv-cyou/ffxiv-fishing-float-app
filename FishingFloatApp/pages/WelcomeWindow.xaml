<Window x:Class="FishingFloatApp.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishingFloatApp"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="欢迎" Height="350" Width="420">
    <Window.Resources>
        <Style TargetType="Button" x:Key="Link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="Blue"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock TextDecorations="Underline">
                            <ContentPresenter />
                        </TextBlock>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label" x:Key="Title">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Label" x:Key="Status">
            <Setter Property="Width" Value="100"/>
        </Style>
    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0">
            <Label Style="{StaticResource Title}">运行环境检查</Label>
            <StackPanel Orientation="Horizontal" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                <Label Content="Webview2:" Width="100"/>
                <Label Name="Webview2Status" Style="{StaticResource Status}" Content="检查中..." />
                <Button Name="Webview2Link" Style="{StaticResource Link}" Click="openWebview2Url" Content="下载链接"/>
                <Button Style="{StaticResource Link}" Click="runCheckes" Content="刷新"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10, 0, 0, 0">
                <Label Content="Npcap:" Width="100"/>
                <Label Name="NpCapStatus" Style="{StaticResource Status}" Content="检查中..." />
                <Button Name="NpCapLink" Style="{StaticResource Link}" Click="openNpcapUrl" Content="下载链接"/>
                <Button Style="{StaticResource Link}" Click="runCheckes" Content="刷新"/>
            </StackPanel>
            <Label Margin="110,0,0,0" Padding="0" FontSize="11" Foreground="Gray">1.81 及更新版本在 Win11 下可能无法正常工作，</Label>
            <Label Margin="110,0,0,0" Padding="0" FontSize="11" Foreground="Gray">若遇到无法识别的问题可尝试降级到 1.80 版本。</Label>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <Label Style="{StaticResource Title}">使用提醒</Label>
            <StackPanel Margin="10, 0, 0, 0">
                <TextBlock TextWrapping="Wrap" Margin="5">1. 程序未使用注入方式，需要先启动程序再从大厅进入游戏。</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="5">2. 网络波动可能会导致数据解析失败，此时需要小退游戏重新进入。</TextBlock>
                <StackPanel Orientation="Horizontal">
                    <Label>3. 若您不介意使用ACT，可以使用我们的悬浮窗版本：</Label>
                    <Button Name="OverlayLink" Style="{StaticResource Link}" Click="openOverlayUrl" Content="链接"/>
                </StackPanel>
                <Label>4. 初次启动请先调整悬浮窗位置，右键点击锁定才能开始使用。</Label>
                <Label>5. 启用内存读取后，可以在游戏中途启动程序，网络波动也会自动恢复</Label>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" >
            <Button Width="100" Click="openHelpUrl" Margin="0,0,20,0">查看帮助</Button>
            <Button Width="100" Click="closeWindow" >确定</Button>
        </StackPanel>
    </Grid>
</Window>
