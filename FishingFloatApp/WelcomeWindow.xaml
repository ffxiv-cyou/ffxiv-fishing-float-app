<Window x:Class="FishingFloatApp.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FishingFloatApp"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="WelcomeWindow" Height="300" Width="400">
    <Window.Resources>
        <Style TargetType="Button" x:Key="Link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="Blue"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock TextDecorations="Underline">
                            <ContentPresenter />
                        </TextBlock>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label" x:Key="Title">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Label" x:Key="Status">
            <Setter Property="Width" Value="100"/>
        </Style>
     </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0">
            <Label Style="{StaticResource Title}">运行环境检查</Label>
            <StackPanel Orientation="Horizontal" Margin="10, 0, 0, 0" VerticalAlignment="Center">
                <Label Content="Webview2:" Width="100"/>
                <Label Name="Webview2Status" Style="{StaticResource Status}" Content="检查中..." />
                <Button Name="Webview2Link" Style="{StaticResource Link}" Click="openWebview2Url" Content="下载链接"/>
                <Button Style="{StaticResource Link}" Click="runCheckes" Content="刷新"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10, 0, 0, 0">
                <Label Content="NpCap:" Width="100"/>
                <Label Name="NpCapStatus" Style="{StaticResource Status}" Content="检查中..." />
                <Button Name="NpCapLink" Style="{StaticResource Link}" Click="openNpcapUrl" Content="下载链接"/>
                <Button Style="{StaticResource Link}" Click="runCheckes" Content="刷新"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1">
            <Label Style="{StaticResource Title}">使用提醒</Label>
            <TextBlock TextWrapping="Wrap" Margin="15, 5, 0, 5">1. 程序未使用注入方式，需要先启动程序再从大厅进入游戏。</TextBlock>
            <TextBlock TextWrapping="Wrap" Margin="15, 5, 0, 5">2. 网络波动可能会导致数据解析失败，此时需要小退游戏重新进入。</TextBlock>
            <StackPanel Orientation="Horizontal" Margin="10, 0, 0, 0">
                <Label>3. 若您不介意使用ACT，建议使用我们的悬浮窗版本：</Label>
                <Button Name="OverlayLink" Style="{StaticResource Link}" Click="openOverlayUrl" Content="链接"/>
            </StackPanel>
        </StackPanel>
        <Button Grid.Row="2" Width="100" Click="Button_Click" >确定</Button>
    </Grid>
</Window>
